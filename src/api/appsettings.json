{
  "App": {
    "Name": "Ludium"
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:3000"]
  },
  "Google": {
    "ClientId": ""
  },
  "Jwt": {
    "Issuer": "https://ludium.app",
    "Audience": "ludium-api",
    "AccessTokenMinutes": 60,
    "SigningKey": ""
  },
  "Auth": {
    "EnableTestLogin": false,
    "RateLimit": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  },
  "ForwardedHeaders": {
    "TrustedNetworks": []
  },
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "localhost"
}
