# Public variables — safe to expose to the browser (NEXT_PUBLIC_ prefix)
NEXT_PUBLIC_API_URL=

# Server-only variables — NEVER add NEXT_PUBLIC_ prefix to these
# Values here are placeholders only — never put real secrets in this file
# Real values go in .env.local (gitignored) locally, and are injected by
# the deployment pipeline in PR and production environments

# Auth.js session encryption secret (generate with `npx auth secret`)
AUTH_SECRET=

# Google OAuth client credentials (one pair per environment)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Non-production ONLY: enables the test-login provider used by E2E tests to sign
# in without the real Google flow. Must never be "true" in production — a
# production build carrying it fails fast at startup. Leave unset/false normally.
AUTH_ENABLE_TEST_LOGIN=false

# Facebook sign-in is a known future addition — not wired up yet
# FACEBOOK_APP_ID=
# FACEBOOK_APP_SECRET=
