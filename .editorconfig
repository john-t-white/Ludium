root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# JSON
[*.json]
indent_style = space
indent_size = 2

# YAML — spaces required
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# Terraform
[*.tf]
indent_style = space
indent_size = 2

# Markdown — preserve trailing spaces (line breaks)
[*.md]
trim_trailing_whitespace = false
